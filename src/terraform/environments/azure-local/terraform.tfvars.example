# =============================================================================
# terraform.tfvars.example — IIC Example Configuration
# =============================================================================
# Copy to terraform.tfvars and update with your site-specific values.
# Generated from config/variables/variables.example.yml
# =============================================================================

org_code = "iic"
location = "eastus"

tags = {
  Environment = "ProjectIIC"
  Project     = "Azure Local Toolkit"
  ManagedBy   = "Terraform"
  Owner       = "admin@contoso.cloud"
  CostCenter  = "IT-IIC"
}

# --- Subscriptions ---
subscriptions = {
  bootstrap_id    = "99999999-9999-9999-9999-999999999999"
  connectivity_id = "44444444-4444-4444-4444-444444444444"
  identity_id     = "77777777-7777-7777-7777-777777777777"
  management_id   = "88888888-8888-8888-8888-888888888888"
  security_id     = "55555555-5555-5555-5555-555555555555"
  azure_local_id  = "33333333-3333-3333-3333-333333333333"
  workloads_id    = "11111111-1111-1111-1111-111111111111"
}

# --- Management Groups ---
management_groups = {
  root_name              = "mg-azlc-projectiic"
  root_display_name      = "Project IIC Root"
  platform_name          = "platform-projectiic"
  platform_display_name  = "Project IIC Platform"
  identity_name          = "platform-identity"
  connectivity_name      = "platform-connectivity"
  management_name        = "platform-management"
  security_name          = "platform-security"
  landing_zones_name     = "lz-projectiic"
}

# --- Resource Groups ---
resource_groups = {
  connectivity_hub    = "rg-iic-connectivity-01"
  connectivity_dns    = "rg-iic-network-01"
  identity_mgmt       = "rg-iic-identity-01"
  management_monitoring = "rg-iic-monitor-01"
  management_backup    = "rg-iic-management-01"
  workload_compute     = "rg-iic-compute-01"
  azurelocal_cluster   = "rg-iic-compute-01"
  azurelocal_arc       = "rg-iic-arc-01"
  azurelocal_network   = "rg-iic-network-01"
  security             = "rg-iic-security-01"
}

# --- Networking ---
vnet_name          = "vnet-iic-management-01"
vnet_address_space = ["10.20.0.0/16"]
dns_servers        = ["192.168.10.10", "192.168.10.11"]

subnets = {
  bastion = {
    name           = "AzureBastionSubnet"
    address_prefix = "10.20.0.0/27"
  }
  gateway = {
    name           = "GatewaySubnet"
    address_prefix = "10.20.0.32/27"
  }
  management = {
    name           = "snet-iic-management"
    address_prefix = "10.20.1.0/24"
  }
  privateendpoints = {
    name           = "snet-iic-privateendpoints"
    address_prefix = "10.20.2.0/24"
  }
}

nsgs = [
  {
    name        = "nsg-iic-management"
    description = "Management network - admin access only"
    rules = [
      {
        name                  = "Allow-RDP-Management"
        priority              = 100
        direction             = "Inbound"
        access                = "Allow"
        protocol              = "Tcp"
        source_address_prefix = "10.100.0.0/24"
        destination_port_range = "3389"
      },
      {
        name                  = "Allow-WinRM"
        priority              = 110
        direction             = "Inbound"
        access                = "Allow"
        protocol              = "Tcp"
        source_address_prefix = "10.100.0.0/24"
        destination_port_range = "5985-5986"
      },
      {
        name                  = "Allow-SSH"
        priority              = 120
        direction             = "Inbound"
        access                = "Allow"
        protocol              = "Tcp"
        source_address_prefix = "10.100.0.0/24"
        destination_port_range = "22"
      },
      {
        name                  = "Deny-All-Inbound"
        priority              = 4000
        direction             = "Inbound"
        access                = "Deny"
        protocol              = "*"
        source_address_prefix = "*"
        destination_port_range = "*"
      }
    ]
  }
]

nsg_subnet_map = {
  management = "nsg-iic-management"
}

enable_nat_gateway = true

# --- VPN ---
enable_vpn_gateway = true
vpn_config = {
  gateway_name           = "vpngw-iic-01"
  public_ip_name         = "pip-iic-vpngw-01"
  sku                    = "VpnGw2AZ"
  generation             = "Generation2"
  active_active          = false
  bgp_enabled            = false
  local_gateway_name     = "lng-iic-site01"
  local_gateway_ip       = "203.0.113.10"
  local_address_prefixes = ["10.0.0.0/24", "10.0.1.0/24"]
  connection_name        = "conn-iic-site01"
  routing_weight         = 0
}

# --- Bastion ---
enable_bastion = true
bastion_config = {
  name           = "bas-iic-connectivity-01"
  public_ip_name = "pip-iic-bastion-01"
  sku            = "Standard"
}

# --- Identity ---
key_vault_name           = "kv-iic-platform"
azl_key_vault_name       = "kv-iic-azl"
deployment_spn_object_id = "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"

# --- Monitoring ---
log_analytics_workspace_name = "law-iic-monitor-01"
log_analytics_retention_days = 90
alert_email_addresses        = ["admin@contoso.cloud"]

# --- Security ---
security_contact_email = "admin@contoso.cloud"

# --- Compute ---
# VM admin password should be provided via environment variable or Key Vault:
#   export TF_VAR_vm_admin_password="$(az keyvault secret show --vault-name kv-iic-platform --name azlocal-admin-password --query value -o tsv)"
vm_admin_username = "azlocaladmin"

management_vms = {
  dc1 = {
    vm_name           = "vm-iic-dc01"
    hostname          = "iic-dc01"
    private_ip        = "10.20.1.10"
    vm_size           = "Standard_D2s_v3"
    subnet_id         = "" # Populated by module reference at runtime
    os_disk_size_gb   = 128
    os_disk_type      = "Premium_LRS"
    role              = "DomainController"
    deployment_target = "azure"
  }
  dc2 = {
    vm_name           = "vm-iic-dc02"
    hostname          = "iic-dc02"
    private_ip        = "10.20.1.11"
    vm_size           = "Standard_D2s_v3"
    subnet_id         = ""
    os_disk_size_gb   = 128
    os_disk_type      = "Premium_LRS"
    role              = "DomainController"
    deployment_target = "azure"
  }
  jumpbox = {
    vm_name           = "vm-iic-jumpbox"
    hostname          = "iic-jumpbox"
    private_ip        = "10.20.1.20"
    vm_size           = "Standard_D2s_v3"
    subnet_id         = ""
    os_disk_size_gb   = 128
    os_disk_type      = "Premium_LRS"
    role              = "Jumpbox"
    deployment_target = "azure"
  }
  wac = {
    vm_name           = "vm-iic-wac01"
    hostname          = "iic-wac01"
    private_ip        = "10.20.1.21"
    vm_size           = "Standard_D2s_v3"
    subnet_id         = ""
    os_disk_size_gb   = 128
    os_disk_type      = "Premium_LRS"
    role              = "WindowsAdminCenter"
    deployment_target = "azure"
  }
  syslog = {
    vm_name           = "vm-iic-syslog01"
    hostname          = "iic-syslog01"
    private_ip        = "10.20.1.50"
    vm_size           = "Standard_B2s"
    subnet_id         = ""
    os_disk_size_gb   = 64
    os_disk_type      = "StandardSSD_LRS"
    role              = "SyslogReceiver"
    deployment_target = "azure"
  }
}
